<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1, user-scalable=no">
<title>happy sweet 16 🎀</title>

<!-- ============================================================
     GOOGLE FONTS — handwritten/script display font + soft body font
     ============================================================ -->
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@500;700&family=Caveat:wght@500;700&family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
/* ================================================================
   ROOT VARIABLES — the whole palette lives here, tweak to taste
   ================================================================ */
:root{
  --blush:#ffd7e9;
  --blush-deep:#ff9fc7;
  --pink-accent:#ff7ab8;
  --cream:#fff7f0;
  --white:#ffffff;
  --gold:#f6d9a4;
  --lace:#ffe9f3;
  --ink:#7a4a5c;
  --shadow:rgba(255,120,180,.35);
  --glass:rgba(255,255,255,.45);
  --glass-border:rgba(255,255,255,.65);
}

*{box-sizing:border-box;}
html,body{
  margin:0;
  padding:0;
  width:100%;
  min-height:100%;
  overflow-x:hidden;
  font-family:'Quicksand',sans-serif;
  background:var(--cream);
  color:var(--ink);
  -webkit-tap-highlight-color:transparent;
}

@media (prefers-reduced-motion: reduce){
  *{animation-duration:.001ms !important; animation-iteration-count:1 !important; transition-duration:.001ms !important;}
}

/* ================================================================
   BACKGROUND LAYER
   --------------------------------------------------------------
   👉 REPLACE THE URL BELOW ("YOUR_BACKGROUND.gif") WITH THE PATH
      TO YOUR OWN BACKGROUND GIF. Upload the gif alongside this
      index.html file (same folder) and just change the filename.
   ================================================================ */
#bg-layer{
  position:fixed;
  inset:0;
  z-index:-3;
  background-image:url('YOUR_BACKGROUND.gif'); /* <-- REPLACE ME */
  background-size:cover;
  background-position:center;
  background-repeat:no-repeat;
  filter:blur(1.5px);
}
/* soft pink overlay + gradient so text stays readable over the gif */
#bg-overlay{
  position:fixed;
  inset:0;
  z-index:-2;
  background:
    radial-gradient(circle at 50% 0%, rgba(255,255,255,.35), transparent 60%),
    linear-gradient(180deg, rgba(255,214,233,.72) 0%, rgba(255,199,224,.65) 45%, rgba(255,235,244,.8) 100%);
  backdrop-filter:blur(2px);
}
/* subtle ambient glow that breathes slowly */
#bg-glow{
  position:fixed;
  inset:0;
  z-index:-1;
  pointer-events:none;
  background:radial-gradient(circle at 50% 30%, rgba(255,255,255,.55), transparent 55%);
  animation:breathe 6s ease-in-out infinite;
}
@keyframes breathe{
  0%,100%{opacity:.5;}
  50%{opacity:.9;}
}

/* ================================================================
   FUGGLERS — 4 peeking creatures, one per corner
   --------------------------------------------------------------
   👉 REPLACE EACH "YOUR_FUGGLER_X.png/gif" BELOW WITH YOUR OWN
      FUGGLER IMAGE OR GIF FILE PATH.
   ================================================================ */
.fuggler-wrap{
  position:fixed;
  z-index:40;
  width:200px;
  height:200px;
  pointer-events:none;
  filter:drop-shadow(0 10px 18px rgba(160,80,120,.35));
}
.fuggler-wrap img{
  width:100%;
  height:100%;
  object-fit:contain;
}
.fuggler-hat{
  position:absolute;
  top:-6%;
  left:50%;
  transform:translateX(-50%) rotate(-8deg);
  width:46px;
  height:46px;
  z-index:2;
}
.fuggler-hat svg{width:100%;height:100%;filter:drop-shadow(0 3px 4px rgba(160,80,120,.3));}
.fuggler-sticker-outline{
  position:absolute;
  inset:6%;
  border-radius:50% 50% 45% 45%;
  border:5px solid white;
  filter:blur(.3px);
  opacity:.9;
  z-index:1;
}

#fuggler-tl{ top:-40px; left:-40px; animation:bobTL 4.2s ease-in-out infinite; }
#fuggler-tr{ top:-40px; right:-40px; animation:bobTR 4.6s ease-in-out infinite; }
#fuggler-bl{ bottom:-40px; left:-40px; animation:bobBL 4.4s ease-in-out infinite; }
#fuggler-br{ bottom:-40px; right:-40px; animation:bobBR 4.8s ease-in-out infinite; }

@keyframes bobTL{
  0%,100%{ transform:translate(0,0) rotate(-3deg);}
  50%{ transform:translate(6px,10px) rotate(2deg);}
}
@keyframes bobTR{
  0%,100%{ transform:translate(0,0) rotate(3deg);}
  50%{ transform:translate(-6px,10px) rotate(-2deg);}
}
@keyframes bobBL{
  0%,100%{ transform:translate(0,0) rotate(3deg);}
  50%{ transform:translate(6px,-10px) rotate(-2deg);}
}
@keyframes bobBR{
  0%,100%{ transform:translate(0,0) rotate(-3deg);}
  50%{ transform:translate(-6px,-10px) rotate(2deg);}
}
.fuggler-wrap.peek-out{ transform:translateY(30px) scale(.94); transition:transform 1.4s cubic-bezier(.34,1.56,.64,1); }
.fuggler-wrap.peek-in{ transform:translateY(0) scale(1); transition:transform 1.4s cubic-bezier(.34,1.56,.64,1); }
.fuggler-wrap.blink{ animation-duration:.18s !important; }

@media (max-width:600px){
  .fuggler-wrap{ width:120px; height:120px; }
  #fuggler-tl,#fuggler-tr{ top:-26px; }
  #fuggler-bl,#fuggler-br{ bottom:-26px; }
  #fuggler-tl,#fuggler-bl{ left:-26px; }
  #fuggler-tr,#fuggler-br{ right:-26px; }
}

/* ================================================================
   FLOATING DECOR LAYER (balloons, hearts, confetti, etc.)
   ================================================================ */
#decor-layer{
  position:fixed;
  inset:0;
  z-index:5;
  overflow:hidden;
  pointer-events:none;
}
.decor-item{
  position:absolute;
  will-change:transform,opacity;
  user-select:none;
}
.float-up{ animation-name:floatUp; animation-timing-function:linear; animation-iteration-count:infinite; }
.float-down{ animation-name:floatDown; animation-timing-function:linear; animation-iteration-count:infinite; }
@keyframes floatUp{
  0%{ transform:translateY(110vh) translateX(0) rotate(0deg); opacity:0; }
  8%{ opacity:1; }
  92%{ opacity:1; }
  100%{ transform:translateY(-20vh) translateX(var(--drift,20px)) rotate(var(--spin,15deg)); opacity:0; }
}
@keyframes floatDown{
  0%{ transform:translateY(-10vh) translateX(0) rotate(0deg); opacity:0; }
  8%{ opacity:1; }
  92%{ opacity:1; }
  100%{ transform:translateY(110vh) translateX(var(--drift,-20px)) rotate(var(--spin,-15deg)); opacity:0; }
}

.balloon{ position:relative; }
.balloon .string{
  position:absolute; left:50%; top:100%; width:1px; height:46px;
  background:rgba(255,255,255,.6); transform:translateX(-50%);
}

.twinkle{
  position:absolute; border-radius:50%;
  background:radial-gradient(circle, #fff 0%, rgba(255,255,255,0) 70%);
  animation:twinkleAnim ease-in-out infinite;
  pointer-events:none;
}
@keyframes twinkleAnim{
  0%,100%{ opacity:0; transform:scale(.4); }
  50%{ opacity:1; transform:scale(1); }
}

.dust{
  position:absolute; border-radius:50%;
  background:rgba(255,255,255,.55);
  animation:dustDrift linear infinite;
  pointer-events:none;
}
@keyframes dustDrift{
  0%{ transform:translate(0,0); opacity:0; }
  10%{ opacity:.8; }
  90%{ opacity:.6; }
  100%{ transform:translate(var(--dx,30px), -120px); opacity:0; }
}

/* ================================================================
   MOUSE / TOUCH SPARKLE TRAIL
   ================================================================ */
.cursor-sparkle{
  position:fixed;
  z-index:9999;
  pointer-events:none;
  font-size:16px;
  animation:sparkleFade 900ms ease-out forwards;
}
@keyframes sparkleFade{
  0%{ opacity:1; transform:translate(-50%,-50%) scale(.6) rotate(0deg); }
  100%{ opacity:0; transform:translate(-50%,-90%) scale(1.3) rotate(90deg); }
}

/* ================================================================
   OPENING SCREEN
   ================================================================ */
#opening-screen{
  position:relative;
  z-index:20;
  min-height:100vh;
  display:flex;
  flex-direction:column;
  align-items:center;
  justify-content:center;
  padding:24px;
  text-align:center;
  transition:opacity .9s ease, transform .9s ease;
}
#opening-screen.hide{
  opacity:0;
  transform:scale(1.05);
  pointer-events:none;
}

.top-heart{
  font-size:42px;
  color:var(--pink-accent);
  margin-bottom:6px;
  animation:pulseHeart 2.2s ease-in-out infinite;
  filter:drop-shadow(0 4px 8px var(--shadow));
}
@keyframes pulseHeart{
  0%,100%{ transform:scale(1); }
  50%{ transform:scale(1.15); }
}

/* ---- Envelope ---- */
#envelope-wrap{
  position:relative;
  width:260px;
  height:180px;
  margin:10px auto 22px;
  cursor:pointer;
  animation:envelopeFloat 3.6s ease-in-out infinite;
}
@keyframes envelopeFloat{
  0%,100%{ transform:translateY(0) rotate(-.6deg); }
  50%{ transform:translateY(-12px) rotate(.6deg); }
}
#envelope-wrap:active{ transform:scale(.97); }

.envelope-body{
  position:absolute;
  inset:0;
  border-radius:14px;
  background:
    linear-gradient(135deg, rgba(255,255,255,.5), rgba(255,255,255,.15)),
    linear-gradient(160deg, var(--cream), var(--lace) 60%, var(--blush) 130%);
  box-shadow:0 18px 34px var(--shadow), inset 0 0 0 1px rgba(255,255,255,.6);
  overflow:hidden;
  border:1px solid rgba(255,255,255,.7);
}
/* paper texture (subtle diagonal lines via repeating gradient) */
.envelope-body::before{
  content:'';
  position:absolute; inset:0;
  background-image:repeating-linear-gradient(135deg, rgba(255,255,255,.25) 0 2px, transparent 2px 6px);
  opacity:.5;
  mix-blend-mode:overlay;
}
.envelope-inner-shadow{
  position:absolute; inset:0;
  background:linear-gradient(180deg, rgba(255,180,210,.25), transparent 40%);
}
.envelope-flap{
  position:absolute;
  top:0; left:0; right:0;
  height:56%;
  background:linear-gradient(150deg, var(--blush), var(--blush-deep));
  clip-path:polygon(0 0, 100% 0, 50% 92%);
  transform-origin:top center;
  transition:transform 1s cubic-bezier(.6,.05,.2,1);
  box-shadow:0 6px 10px rgba(190,90,130,.25) inset;
  z-index:3;
}
#envelope-wrap.open .envelope-flap{
  transform:rotateX(180deg);
}
.wax-seal{
  position:absolute;
  top:50%; left:50%;
  width:52px; height:52px;
  transform:translate(-50%,-50%);
  border-radius:50%;
  background:radial-gradient(circle at 35% 30%, #ff9fc0, #e8578e 70%);
  box-shadow:0 4px 10px rgba(160,40,90,.45), inset 0 0 0 2px rgba(255,255,255,.25);
  display:flex; align-items:center; justify-content:center;
  color:#fff; font-size:20px;
  z-index:5;
  transition:transform .5s ease, opacity .5s ease;
}
#envelope-wrap.open .wax-seal{
  transform:translate(-50%,-50%) scale(1.4) rotate(25deg);
  opacity:0;
}
.envelope-letter{
  position:absolute;
  left:8%; right:8%;
  bottom:6%;
  height:82%;
  background:linear-gradient(180deg,#fff,#fff7fb);
  border-radius:10px;
  box-shadow:0 -4px 12px rgba(220,150,180,.25);
  z-index:2;
  transform:translateY(0);
  transition:transform 1.1s cubic-bezier(.34,1.56,.64,1) .35s;
  display:flex;
  align-items:center;
  justify-content:center;
  font-family:'Dancing Script',cursive;
  color:var(--pink-accent);
  font-size:26px;
}
#envelope-wrap.open .envelope-letter{
  transform:translateY(-135%);
}
.envelope-front-heart{
  position:absolute; bottom:8px; right:12px; font-size:14px; color:var(--pink-accent); opacity:.8; z-index:4;
}

#click-hint{
  font-family:'Quicksand',sans-serif;
  font-weight:600;
  font-size:15px;
  letter-spacing:.3px;
  color:var(--pink-accent);
  text-shadow:0 2px 6px rgba(255,255,255,.6);
  animation:hintPulse 1.8s ease-in-out infinite;
  text-transform:lowercase;
}
@keyframes hintPulse{
  0%,100%{ opacity:.7; transform:translateY(0); }
  50%{ opacity:1; transform:translateY(-3px); }
}

/* ================================================================
   CONFETTI (burst on envelope open)
   ================================================================ */
.confetti-piece{
  position:fixed;
  z-index:60;
  pointer-events:none;
  top:50%;
  left:50%;
  border-radius:2px;
}

/* ================================================================
   BIRTHDAY CARD SCREEN
   ================================================================ */
#card-screen{
  position:relative;
  z-index:15;
  min-height:100vh;
  display:none;
  align-items:center;
  justify-content:center;
  padding:40px 18px 60px;
}
#card-screen.show{ display:flex; }

#card{
  position:relative;
  max-width:560px;
  width:100%;
  background:var(--glass);
  backdrop-filter:blur(18px) saturate(140%);
  border:1px solid var(--glass-border);
  border-radius:32px;
  padding:44px 34px 30px;
  box-shadow:0 30px 60px -10px var(--shadow), 0 0 0 1px rgba(255,255,255,.4) inset;
  opacity:0;
  transform:translateY(50px) scale(.94);
  animation:cardEnter 1.1s cubic-bezier(.2,.9,.25,1) forwards;
  animation-delay:.1s;
}
@keyframes cardEnter{
  to{ opacity:1; transform:translateY(0) scale(1); }
}
#card.settled{
  animation:cardFloat 6s ease-in-out infinite;
}
@keyframes cardFloat{
  0%,100%{ transform:translateY(0); }
  50%{ transform:translateY(-8px); }
}

/* lace border effect */
#card::before{
  content:'';
  position:absolute;
  inset:10px;
  border-radius:24px;
  border:2px dashed rgba(255,159,199,.55);
  pointer-events:none;
}
#card::after{
  content:'';
  position:absolute;
  inset:-2px;
  border-radius:34px;
  padding:2px;
  background:linear-gradient(120deg, var(--gold), var(--blush-deep), var(--gold));
  -webkit-mask:linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite:xor;
  mask-composite:exclude;
  opacity:.7;
  pointer-events:none;
}

.card-corner{
  position:absolute;
  font-size:26px;
  opacity:.9;
  filter:drop-shadow(0 2px 4px rgba(255,255,255,.6));
}
.card-corner.tl{ top:14px; left:18px; }
.card-corner.tr{ top:14px; right:18px; transform:scaleX(-1); }
.card-corner.bl{ bottom:14px; left:18px; }
.card-corner.br{ bottom:14px; right:18px; transform:scaleX(-1); }

.card-title{
  font-family:'Dancing Script',cursive;
  font-size:44px;
  text-align:center;
  color:var(--pink-accent);
  margin:0 0 6px;
  text-shadow:0 3px 10px rgba(255,150,190,.4);
}
.card-subtitle{
  text-align:center;
  font-size:13px;
  letter-spacing:2px;
  text-transform:uppercase;
  color:var(--ink);
  opacity:.65;
  margin-bottom:22px;
}

#message-box{
  font-family:'Caveat',cursive;
  font-size:23px;
  line-height:1.65;
  color:#8a4f66;
  white-space:pre-wrap;
  min-height:260px;
}
#message-box .cursor-blink{
  display:inline-block;
  width:2px;
  background:var(--pink-accent);
  animation:blink 1s step-start infinite;
  margin-left:1px;
}
@keyframes blink{ 50%{ opacity:0; } }

.mini-decor{
  position:absolute;
  font-size:20px;
  animation:sway 4s ease-in-out infinite;
  opacity:.85;
}
@keyframes sway{
  0%,100%{ transform:rotate(-6deg) translateY(0); }
  50%{ transform:rotate(6deg) translateY(-4px); }
}

/* ================================================================
   CASSETTE PLAYER
   --------------------------------------------------------------
   👉 REPLACE THE URL IN THE JS SECTION BELOW ("MUSIC_LINK") IF YOU
      WANT TO POINT TO A DIFFERENT SONG / PLATFORM.
   ================================================================ */
#cassette-wrap{
  margin-top:30px;
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:10px;
}
#cassette{
  width:100%;
  max-width:300px;
  aspect-ratio:1.6/1;
  border-radius:18px;
  background:linear-gradient(160deg, #ffe3f0, #ffc9e2 60%, #ffb3d9);
  box-shadow:0 14px 26px var(--shadow), inset 0 0 0 1px rgba(255,255,255,.6);
  position:relative;
  display:flex;
  align-items:center;
  justify-content:space-around;
  padding:0 22px;
  cursor:pointer;
  transition:transform .25s ease;
  border:1px solid rgba(255,255,255,.8);
}
#cassette:hover{ transform:translateY(-4px) scale(1.02); }
#cassette:active{ transform:scale(.97); }
.reel{
  width:52px; height:52px;
  border-radius:50%;
  background:radial-gradient(circle at 40% 35%, #fff, #ffd6ea 55%, #ff9fc7 100%);
  box-shadow:0 3px 8px rgba(200,90,140,.4), inset 0 0 0 6px rgba(255,255,255,.55);
  position:relative;
}
.reel::after{
  content:'';
  position:absolute; inset:38%;
  border-radius:50%;
  background:#fff;
  box-shadow:0 0 0 2px var(--pink-accent);
}
.reel.spin{ animation:spinReel 1.1s linear infinite; }
@keyframes spinReel{ to{ transform:rotate(360deg); } }
.cassette-label{
  position:absolute;
  top:10px; left:50%;
  transform:translateX(-50%);
  background:rgba(255,255,255,.75);
  border-radius:10px;
  padding:2px 10px;
  font-size:10px;
  font-family:'Quicksand',sans-serif;
  font-weight:700;
  letter-spacing:.5px;
  color:var(--pink-accent);
  white-space:nowrap;
}
#play-btn{
  position:absolute;
  bottom:10px; left:50%;
  transform:translateX(-50%);
  width:38px; height:38px;
  border-radius:50%;
  background:linear-gradient(160deg,#fff,#ffd6ea);
  box-shadow:0 4px 10px rgba(200,90,140,.5), inset 0 0 0 1px rgba(255,255,255,.8);
  display:flex; align-items:center; justify-content:center;
  color:var(--pink-accent);
  font-size:14px;
  border:none;
}
#cassette-caption{
  font-size:12px;
  color:var(--ink);
  opacity:.7;
  text-align:center;
  font-family:'Quicksand',sans-serif;
}

.card-footer-heart{
  text-align:center;
  margin-top:26px;
  font-size:22px;
  color:var(--pink-accent);
  animation:pulseHeart 2.4s ease-in-out infinite;
}

@media (max-width:480px){
  .card-title{ font-size:34px; }
  #message-box{ font-size:19px; min-height:220px; }
  #envelope-wrap{ width:220px; height:150px; }
}
</style>
</head>
<body>

<!-- ============== BACKGROUND ============== -->
<div id="bg-layer"></div>
<div id="bg-overlay"></div>
<div id="bg-glow"></div>

<!-- ============== FUGGLERS (peeking from 4 corners) ==============
     👉 Replace the src="YOUR_FUGGLER_1.png" etc. below with your own
        Fuggler images/gifs. Recommended transparent PNG or GIF.
-->
<div class="fuggler-wrap" id="fuggler-tl">
  <div class="fuggler-sticker-outline"></div>
  <div class="fuggler-hat">
    <svg viewBox="0 0 40 40"><polygon points="20,2 6,34 34,34" fill="#ffd6ea" stroke="#fff" stroke-width="2"/><circle cx="20" cy="2" r="4" fill="#ff9fc7"/></svg>
  </div>
  <img src="YOUR_FUGGLER_1.png" alt="fuggler peeking top left">
</div>
<div class="fuggler-wrap" id="fuggler-tr">
  <div class="fuggler-sticker-outline"></div>
  <div class="fuggler-hat">
    <svg viewBox="0 0 40 40"><polygon points="20,2 6,34 34,34" fill="#c9f5ff" stroke="#fff" stroke-width="2"/><circle cx="20" cy="2" r="4" fill="#7ad9ff"/></svg>
  </div>
  <img src="YOUR_FUGGLER_2.png" alt="fuggler peeking top right">
</div>
<div class="fuggler-wrap" id="fuggler-bl">
  <div class="fuggler-sticker-outline"></div>
  <div class="fuggler-hat">
    <svg viewBox="0 0 40 40"><polygon points="20,2 6,34 34,34" fill="#fff3c9" stroke="#fff" stroke-width="2"/><circle cx="20" cy="2" r="4" fill="#ffd76a"/></svg>
  </div>
  <img src="YOUR_FUGGLER_3.png" alt="fuggler peeking bottom left">
</div>
<div class="fuggler-wrap" id="fuggler-br">
  <div class="fuggler-sticker-outline"></div>
  <div class="fuggler-hat">
    <svg viewBox="0 0 40 40"><polygon points="20,2 6,34 34,34" fill="#e3d6ff" stroke="#fff" stroke-width="2"/><circle cx="20" cy="2" r="4" fill="#c3a3ff"/></svg>
  </div>
  <img src="YOUR_FUGGLER_4.png" alt="fuggler peeking bottom right">
</div>

<!-- ============== FLOATING DECOR (generated by JS below) ============== -->
<div id="decor-layer"></div>

<!-- ============== OPENING SCREEN ============== -->
<div id="opening-screen">
  <div class="top-heart">♡</div>

  <div id="envelope-wrap">
    <div class="envelope-body">
      <div class="envelope-inner-shadow"></div>
      <div class="envelope-letter">✨ for you ✨</div>
      <div class="envelope-flap"></div>
      <div class="wax-seal">♥</div>
      <div class="envelope-front-heart">🎀</div>
    </div>
  </div>

  <div id="click-hint">wowow click dis 🎀</div>
</div>

<!-- ============== BIRTHDAY CARD SCREEN ============== -->
<div id="card-screen">
  <div id="card">
    <span class="card-corner tl">🎀</span>
    <span class="card-corner tr">🎀</span>
    <span class="card-corner bl">🌸</span>
    <span class="card-corner br">🌸</span>

    <h1 class="card-title">happy birthday</h1>
    <div class="card-subtitle">✧ sweet sixteen ✧</div>

    <!--
      ============================================================
      👉 REPLACE THE MESSAGE TEXT BELOW (inside the JS "cardMessage"
         variable, near the bottom of the file) TO CHANGE THE
         BIRTHDAY MESSAGE. It currently preserves the exact line
         breaks requested.
      ============================================================
    -->
    <div id="message-box"></div>

    <!-- ============== CASSETTE PLAYER ==============
         👉 To change the song, edit MUSIC_LINK in the JS section.
    -->
    <div id="cassette-wrap">
      <div id="cassette" title="press play">
        <div class="reel" id="reel-left"></div>
        <div class="cassette-label">flaming hot cheetos 🎀</div>
        <div class="reel" id="reel-right"></div>
        <button id="play-btn">▶</button>
      </div>
      <div id="cassette-caption">tap to play on youtube</div>
    </div>

    <div class="card-footer-heart">♡ ⋆｡ ♡ ⋆｡ ♡</div>
  </div>
</div>

<script>
/* ================================================================
   CONFIG — the two things most people will want to edit live here
   ================================================================ */
const cardMessage =
`Haii!! 🎀💗

Happy 16th birthdayyy! 🥳🎉 I hope today is filled with so much love, laughter, and happiness. You deserve the sweetest day ever, hahaha (get it 'cause sweet 16 😭🩷).

Thank you for being such an amazing person. 🫶 I'm really grateful I got to know you, and I hope this year brings you so many new memories, opportunities, and moments that make you genuinely happeee. ✨

Keep being you, never let anyone dim your sparkle! 🌟 Can't wait to see you achieve your dreams little by little. 💗

Happy sweet 16!! 🎂🎀🤍`;

const MUSIC_LINK = "https://www.youtube.com/results?search_query=Flaming+Hot+Cheetos+Clairo"; // 👉 replace with official video/track link if you have one

/* ================================================================
   FLOATING BACKGROUND DECOR GENERATOR
   ================================================================ */
(function initDecor(){
  const layer = document.getElementById('decor-layer');
  const upEmojis = ['🎈','💗','🩷','🎀','⭐','✨','🫧','🎉'];
  const downEmojis = ['💕','🌸','🎀','❤️','🩷','⭐'];
  const cakeEmojis = ['🎂','🧁','🕯️','🍰'];

  function spawn(emoji, direction){
    const el = document.createElement('div');
    el.className = 'decor-item ' + (direction === 'up' ? 'float-up' : 'float-down');
    const isBalloon = emoji === '🎈';
    if(isBalloon){
      el.classList.add('balloon');
      el.innerHTML = emoji + '<div class="string"></div>';
    } else {
      el.textContent = emoji;
    }
    const size = 18 + Math.random()*26;
    el.style.fontSize = size + 'px';
    el.style.left = (Math.random()*94) + 'vw';
    const duration = 9 + Math.random()*10;
    el.style.animationDuration = duration + 's';
    el.style.animationDelay = (Math.random()*6) + 's';
    el.style.setProperty('--drift', (Math.random()*80-40) + 'px');
    el.style.setProperty('--spin', (Math.random()*40-20) + 'deg');
    el.style.opacity = '0';
    el.style.zIndex = Math.floor(2+Math.random()*4);
    layer.appendChild(el);
    setTimeout(()=>{ el.remove(); spawn(emoji, direction); }, (duration+6)*1000);
  }

  const allUp = upEmojis.concat(cakeEmojis);
  for(let i=0;i<16;i++){ spawn(allUp[Math.floor(Math.random()*allUp.length)], 'up'); }
  for(let i=0;i<10;i++){ spawn(downEmojis[Math.floor(Math.random()*downEmojis.length)], 'down'); }

  // twinkles
  function spawnTwinkle(){
    const t = document.createElement('div');
    t.className = 'twinkle';
    const size = 4 + Math.random()*10;
    t.style.width = size+'px';
    t.style.height = size+'px';
    t.style.left = (Math.random()*100)+'vw';
    t.style.top = (Math.random()*100)+'vh';
    t.style.animationDuration = (1.4+Math.random()*2)+'s';
    layer.appendChild(t);
    setTimeout(()=>t.remove(), 4000);
  }
  setInterval(spawnTwinkle, 250);

  // floating dust particles
  function spawnDust(){
    const d = document.createElement('div');
    d.className = 'dust';
    const size = 2 + Math.random()*4;
    d.style.width = size+'px';
    d.style.height = size+'px';
    d.style.left = (Math.random()*100)+'vw';
    d.style.top = (60+Math.random()*40)+'vh';
    d.style.setProperty('--dx', (Math.random()*60-30)+'px');
    d.style.animationDuration = (8+Math.random()*6)+'s';
    layer.appendChild(d);
    setTimeout(()=>d.remove(), 15000);
  }
  setInterval(spawnDust, 600);
})();

/* ================================================================
   FUGGLER LIFE — occasional blink / peek in-out
   ================================================================ */
(function fugglerLife(){
  const ids = ['fuggler-tl','fuggler-tr','fuggler-bl','fuggler-br'];
  ids.forEach((id, idx)=>{
    const el = document.getElementById(id);
    setInterval(()=>{
      el.classList.add('peek-out');
      setTimeout(()=>el.classList.remove('peek-out'), 1300);
    }, 6000 + idx*1500 + Math.random()*2000);
  });
})();

/* ================================================================
   CURSOR / TOUCH SPARKLE TRAIL
   ================================================================ */
(function sparkleTrail(){
  const sparkles = ['✨','💗','⭐','🩷'];
  let last = 0;
  function makeSparkle(x, y){
    const now = Date.now();
    if(now - last < 60) return; // throttle for perf
    last = now;
    const s = document.createElement('div');
    s.className = 'cursor-sparkle';
    s.textContent = sparkles[Math.floor(Math.random()*sparkles.length)];
    s.style.left = x+'px';
    s.style.top = y+'px';
    document.body.appendChild(s);
    setTimeout(()=>s.remove(), 900);
  }
  window.addEventListener('mousemove', e => makeSparkle(e.clientX, e.clientY));
  window.addEventListener('touchmove', e => {
    for(const t of e.touches) makeSparkle(t.clientX, t.clientY);
  }, {passive:true});
})();

/* ================================================================
   ENVELOPE OPEN SEQUENCE
   ================================================================ */
(function envelopeSequence(){
  const wrap = document.getElementById('envelope-wrap');
  const opening = document.getElementById('opening-screen');
  const cardScreen = document.getElementById('card-screen');
  const hint = document.getElementById('click-hint');
  let opened = false;

  wrap.addEventListener('click', () => {
    if(opened) return;
    opened = true;
    hint.style.visibility = 'hidden';

    // 1. seal breaks + flap opens + letter slides up
    wrap.classList.add('open');

    // 2. confetti burst
    setTimeout(burstConfetti, 550);

    // 3. transition to card
    setTimeout(()=>{
      opening.classList.add('hide');
      setTimeout(()=>{
        opening.style.display = 'none';
        cardScreen.classList.add('show');
        startTypewriter();
        setTimeout(()=>document.getElementById('card').classList.add('settled'), 1100);
      }, 900);
    }, 1700);
  });

  function burstConfetti(){
    const colors = ['#ff9fc7','#ffd6ea','#f6d9a4','#ffffff','#ff7ab8'];
    const count = 60;
    for(let i=0;i<count;i++){
      const p = document.createElement('div');
      p.className = 'confetti-piece';
      const size = 6 + Math.random()*8;
      p.style.width = size+'px';
      p.style.height = (size*0.4+4)+'px';
      p.style.background = colors[Math.floor(Math.random()*colors.length)];
      const angle = Math.random()*2*Math.PI;
      const dist = 120 + Math.random()*260;
      const dx = Math.cos(angle)*dist;
      const dy = Math.sin(angle)*dist - 80;
      p.style.transform = 'translate(-50%,-50%)';
      document.body.appendChild(p);
      const anim = p.animate([
        { transform:'translate(-50%,-50%) rotate(0deg)', opacity:1 },
        { transform:`translate(calc(-50% + ${dx}px), calc(-50% + ${dy+300}px)) rotate(${360+Math.random()*360}deg)`, opacity:0 }
      ], { duration: 1600+Math.random()*900, easing:'cubic-bezier(.2,.7,.3,1)' });
      anim.onfinish = () => p.remove();
    }
  }
})();

/* ================================================================
   TYPEWRITER EFFECT FOR CARD MESSAGE
   ================================================================ */
function startTypewriter(){
  const box = document.getElementById('message-box');
  box.textContent = '';
  const cursor = document.createElement('span');
  cursor.className = 'cursor-blink';
  cursor.textContent = '\u00A0';

  let i = 0;
  const speed = 26;
  function type(){
    if(i < cardMessage.length){
      box.textContent = cardMessage.slice(0, i+1);
      box.appendChild(cursor);
      i++;
      const ch = cardMessage[i-1];
      const delay = (ch === '\n') ? speed*8 : speed;
      setTimeout(type, delay);
    } else {
      box.appendChild(cursor);
    }
  }
  type();
}

/* ================================================================
   CASSETTE PLAYER — spin + open music link
   ================================================================ */
(function cassette(){
  const cassetteEl = document.getElementById('cassette');
  const reelL = document.getElementById('reel-left');
  const reelR = document.getElementById('reel-right');
  let playing = false;

  function toggle(){
    playing = !playing;
    reelL.classList.toggle('spin', playing);
    reelR.classList.toggle('spin', playing);
    if(playing){
      window.open(MUSIC_LINK, '_blank', 'noopener');
      setTimeout(()=>{ playing=false; reelL.classList.remove('spin'); reelR.classList.remove('spin'); }, 4000);
    }
  }
  cassetteEl.addEventListener('click', toggle);
})();
</script>
</body>
</html>
